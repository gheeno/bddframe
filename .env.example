# BDDFrame config — this file IS committed. NO SECRETS here.
#   - Secrets (credentials/tokens) → secrets.env (gitignored). See secrets.env.example.
#     For now secrets live in that property file; soon they move to Azure Key Vault (AKV).
#   - Base URLs → environments.yaml (referenced as [SAUCEDEMO] etc. in .feature files).

# Browser settings
BDDFRAME_BROWSER=chromium        # chromium | firefox | webkit
BDDFRAME_HEADLESS=false          # true in CI
BDDFRAME_TIMEOUT=10000           # milliseconds
BDDFRAME_STRICT_LOCATOR=false    # true = ambiguous locators FAIL instead of using first match (recommended in CI)
BDDFRAME_CONFIDENCE=0.85         # OpenCV template match threshold (visual agent)

# LLM (optional — enables step fallback and semantic assertions)
#
# BDDFRAME_LLM_MODE=auto          # auto (default): patterns first, LLM on no-match
#                                  # full: skip patterns, every step resolved by LLM
#
# ── Local / free ──────────────────────────────────────────────────────────────
# BDDFRAME_MODEL=ollama/llama3
# BDDFRAME_LLM_URL=http://localhost:11434
# BDDFRAME_VISION_MODEL=ollama/llava
#
# Google Gemini (free tier, vision-capable — no BDDFRAME_LLM_URL needed):
# BDDFRAME_MODEL=gemini/gemini-1.5-flash
# GEMINI_API_KEY=...
#
# Groq (free tier, text only — very fast):
# BDDFRAME_MODEL=groq/llama-3.1-8b-instant
# GROQ_API_KEY=...
#
# ── Paid / hosted ─────────────────────────────────────────────────────────────
# Anthropic Claude (vision-capable — recommended for full mode):
# BDDFRAME_MODEL=anthropic/claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...
#
# Anthropic Claude Haiku (cheapest Claude, text only):
# BDDFRAME_MODEL=anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# Agentic RCA (optional) — on a step FAILURE, a vision model classifies the root
# cause (app-regression | locator-rot | environment-flap | test-data | test-script)
# and tags the Allure report. Needs BDDFRAME_MODEL (vision-capable). Off by
# default; best-effort, fires only on failure (one model call per failed step).
# BDDFRAME_RCA=false

# OpenAI:
# BDDFRAME_MODEL=openai/gpt-4o-mini
# BDDFRAME_LLM_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# For Foundry Local (local model, no Ollama/Hugging Face — works on locked-down networks).
# Start it first: `foundry model run qwen2.5-7b`, then read id/port from `foundry service status`.
# BDDFRAME_MODEL=openai/qwen2.5-7b-instruct-generic-cpu   # exact id from `foundry model list`
# BDDFRAME_LLM_URL=http://localhost:5273/v1               # port varies — confirm it
# OPENAI_API_KEY=not-needed                               # required to be set, value ignored locally
